# Backlog provider (jira, file)
export RALPH_PROVIDER="jira"

# Model provider (claude, gemini, codex)
export RALPH_MODEL_PROVIDER="claude"

# Jira-specific (when RALPH_PROVIDER=jira)
export JIRA_EMAIL="you@example.com"
export JIRA_API_TOKEN="your-api-token"
export JIRA_BASE_URL="https://yourorg.atlassian.net"

# File-specific (when RALPH_PROVIDER=file)
# export RALPH_PRD_FILE="./prd.md"  # Optional, defaults to ./prd.md

# Polling interval in seconds (default: 15)
export RALPH_POLL_INTERVAL=5

# Session log directory (unset = no logs saved)
# export RALPH_LOG_DIR="./ralph-logs"

# Worktree setup command — runs every agent start inside the worktree.
# export RALPH_WORKTREE_SETUP="bash scripts/worktree-setup.sh && npm install"
