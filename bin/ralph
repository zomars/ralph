#!/bin/zsh
set -e

RALPH_HOME="$(cd "$(dirname "$(realpath "$0")")/.." && pwd)"
source "$RALPH_HOME/lib/ralph-core.sh"
ralph_init

RALPH_VERSION="1.0.0"

usage() {
  cat <<EOF
ralph — Autonomous agent ecosystem for backlog-driven SDLC

Usage: ralph <command> [options]

Agent commands (Jira-driven):
  planner           Run the Planner agent (AFK loop by default)
  implementer       Run the Implementer agent
  reviewer          Run the Reviewer agent
  tester            Run the Tester agent
  refactor          Run the Refactorer agent
  documenter        Run the Documenter agent

GitHub commands:
  fixer             Run the Fixer agent (responds to PR review feedback)
  merger            Run the Merger agent (auto-merges approved PRs)

Agent options:
  --once            Run a single iteration, then exit
  --afk             Run in AFK loop mode (default)

Debugging:
  debug <agent> [N] Tail a running agent's output (default: instance 1)
    -f, --follow    Live tail (like tail -f)
    -n, --lines N   Number of lines to show (default: 200)
    --raw           Show raw JSON instead of rendered text

Utility commands:
  validate          Run routing validation (accepts --matrix, --check-prompts, --check-loops, --check-all)
  init              Create a .ralphrc file in the current directory
  config            Show current configuration
  version           Show version
  help              Show this help message
EOF
}

cmd_init() {
  if [[ -f ".ralphrc" ]]; then
    echo ".ralphrc already exists in this directory."
    exit 1
  fi
  cp "$RALPH_HOME/.ralphrc.example" ".ralphrc"
  echo "Created .ralphrc — edit it with your provider credentials."

  if [[ ! -f ".mcp.json" ]]; then
    cat > ".mcp.json" <<'MCPEOF'
{
  "mcpServers": {
    "jira": {
      "command": "ralph-jira-mcp"
    }
  }
}
MCPEOF
    echo "Created .mcp.json — Jira MCP server configured."
  fi
}

cmd_config() {
  source "$RALPH_HOME/lib/ralph-core.sh"
  local agent_cli
  agent_cli=$(ralph_get_agent_cli)

  echo "RALPH_HOME:           $RALPH_HOME"
  echo "RALPH_PROVIDER:       $RALPH_PROVIDER"
  echo "RALPH_MODEL_PROVIDER: $RALPH_MODEL_PROVIDER (cli: $agent_cli)"
  echo "RALPH_VERSION:        $RALPH_VERSION"
  echo ""
  echo "Provider:       $RALPH_HOME/lib/providers/$RALPH_PROVIDER.sh"
  echo "Instructions:   $RALPH_HOME/providers/$RALPH_PROVIDER/instructions.md"
  echo "Routing:        $RALPH_HOME/providers/$RALPH_PROVIDER/routing.json"
  echo "Prompts:        $RALPH_HOME/prompts/"
  echo ""

  if [[ -f ".ralphrc" ]]; then
    echo "Local config:   $(pwd)/.ralphrc"
  else
    echo "Local config:   (none — run 'ralph init' to create .ralphrc)"
  fi
}

cmd_version() {
  echo "ralph $RALPH_VERSION"
}

# Agent key → display name mapping
agent_display_name() {
  case "$1" in
    planner)      echo "Planner" ;;
    implementer)  echo "Implementer" ;;
    reviewer)     echo "Reviewer" ;;
    tester)       echo "Tester" ;;
    refactor)     echo "Refactorer" ;;
    documenter)   echo "Documenter" ;;
    fixer)        echo "Fixer" ;;
    merger)       echo "Merger" ;;
  esac
}

cmd_agent() {
  local agent_key="$1"
  shift
  local agent_name
  agent_name=$(agent_display_name "$agent_key")

  # Parse --once / --afk
  local run_once="false"
  for arg in "$@"; do
    case "$arg" in
      --once) run_once="true" ;;
      --afk)  run_once="false" ;;
      *)
        echo "Unknown option for '$agent_key': $arg"
        echo "Usage: ralph $agent_key [--once|--afk]"
        exit 1
        ;;
    esac
  done

  source "$RALPH_HOME/lib/ralph-gated-loop.sh"

  if [[ "$run_once" == "true" ]]; then
    ralph_gated_loop_once "$agent_key" "$agent_name"
  else
    ralph_gated_loop "$agent_key" "$agent_name"
  fi
}

cmd_github_agent() {
  local agent_key="$1"
  shift
  local agent_name
  agent_name=$(agent_display_name "$agent_key")

  # Parse --once / --afk
  local run_once="false"
  for arg in "$@"; do
    case "$arg" in
      --once) run_once="true" ;;
      --afk)  run_once="false" ;;
      *)
        echo "Unknown option for '$agent_key': $arg"
        echo "Usage: ralph $agent_key [--once|--afk]"
        exit 1
        ;;
    esac
  done

  source "$RALPH_HOME/lib/ralph-github-loop.sh"

  if [[ "$run_once" == "true" ]]; then
    ralph_github_loop_once "$agent_key" "$agent_name"
  else
    ralph_github_loop "$agent_key" "$agent_name"
  fi
}

cmd_debug() {
  # Parse args: ralph debug <agent> [instance] [-f|--follow] [-n|--lines N] [--raw]
  local agent_key="" instance_num=1 follow=false raw=false lines=200

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f|--follow) follow=true; shift ;;
      --raw) raw=true; shift ;;
      -n|--lines) lines="$2"; shift 2 ;;
      -*)
        echo "Unknown option: $1"
        echo "Usage: ralph debug <agent> [instance] [-f|--follow] [-n|--lines N] [--raw]"
        exit 1
        ;;
      *)
        if [[ -z "$agent_key" ]]; then
          agent_key="$1"
        else
          instance_num="$1"
        fi
        shift
        ;;
    esac
  done

  if [[ -z "$agent_key" ]]; then
    echo "Usage: ralph debug <agent> [instance] [-f|--follow] [-n|--lines N] [--raw]"
    echo ""
    echo "Agents: planner, implementer, reviewer, tester, refactor, documenter, fixer, merger"
    exit 1
  fi

  # Validate agent name
  case "$agent_key" in
    planner|implementer|reviewer|tester|refactor|documenter|fixer|merger) ;;
    *)
      echo "Unknown agent: $agent_key"
      echo "Agents: planner, implementer, reviewer, tester, refactor, documenter, fixer, merger"
      exit 1
      ;;
  esac

  source "$RALPH_HOME/lib/ralph-core.sh"
  ralph_get_jq_filters
  local stream_text="$RALPH_STREAM_FILTER"

  # Try live session log first
  local session_log="/tmp/ralph-${agent_key}/${instance_num}/session.log"
  local log_file=""

  if [[ -f "$session_log" ]]; then
    log_file="$session_log"
  elif [[ -n "${RALPH_LOG_DIR:-}" ]]; then
    # Fallback: latest saved session log
    local log_dir="${RALPH_LOG_DIR%/}/${agent_key}-${instance_num}"
    if [[ -d "$log_dir" ]]; then
      log_file=$(ls -t "$log_dir"/*-session.log 2>/dev/null | head -1)
    fi
  fi

  if [[ -z "$log_file" ]]; then
    echo "No session log found for ${agent_key} #${instance_num}."
    echo ""
    echo "Checked:"
    echo "  Live:  $session_log"
    [[ -n "${RALPH_LOG_DIR:-}" ]] && echo "  Saved: ${RALPH_LOG_DIR%/}/${agent_key}-${instance_num}/"
    [[ -z "${RALPH_LOG_DIR:-}" ]] && echo "  Tip:   Set RALPH_LOG_DIR in .ralphrc to persist logs across sessions."
    exit 1
  fi

  local source_label="live"
  [[ "$log_file" != "$session_log" ]] && source_label="saved"
  echo "── ${agent_key} #${instance_num} ($source_label: $log_file) ──"
  echo ""

  _debug_render "$log_file" "$stream_text" "$follow" "$raw" "$lines"
}

_debug_render() {
  local log_file="$1" stream_text="$2" follow="$3" raw="$4" lines="$5"

  if [[ "$follow" == "true" ]]; then
    if [[ "$raw" == "true" ]]; then
      tail -f "$log_file"
    else
      tail -f "$log_file" \
        | grep --line-buffered '^{' \
        | jq --unbuffered -rj "$stream_text"
    fi
  else
    if [[ "$raw" == "true" ]]; then
      tail -n "$lines" "$log_file"
    else
      grep '^{' "$log_file" \
        | jq -rj "$stream_text" \
        | tail -n "$lines"
    fi
  fi
}

subcmd="${1:-}"
[[ -n "$subcmd" ]] && shift

case "$subcmd" in
  init)               cmd_init ;;
  config)             cmd_config ;;
  debug)              cmd_debug "$@" ;;
  version|-v)         cmd_version ;;
  help|--help|-h|"")  usage ;;
  validate)           exec "$RALPH_HOME/bin/validate-routing-impl" "$@" ;;
  planner|implementer|reviewer|tester|refactor|documenter)
                      cmd_agent "$subcmd" "$@" ;;
  fixer|merger)       cmd_github_agent "$subcmd" "$@" ;;
  *)
    echo "Unknown command: $subcmd"
    echo "Run 'ralph help' for usage."
    exit 1
    ;;
esac
