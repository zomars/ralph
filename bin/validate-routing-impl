#!/bin/bash
set -eo pipefail

# Ralph Routing Validator
# Validates routing.json for overlaps, gaps, and drift from prompt files.
#
# Usage:
#   validate-routing              # Default: simulate ticket states, report overlaps/gaps
#   validate-routing --matrix     # Full matrix output
#   validate-routing --check-prompts  # Check JQL drift between routing.json and prompt files
#   validate-routing --check-loops    # Check for self-loop and global-exclude violations
#   validate-routing --check-core     # Check core behaviors (CLI routing, filters, promises)
#   validate-routing --check-all      # Run all checks

RALPH_HOME="$(cd "$(dirname "$(realpath "$0")")/.." && pwd)"

# Load provider from .ralphrc or default to jira
if [[ -f ".ralphrc" ]]; then
  source ".ralphrc"
fi
RALPH_PROVIDER="${RALPH_PROVIDER:-jira}"

ROUTING_JSON="$RALPH_HOME/providers/$RALPH_PROVIDER/routing.json"

if [ ! -f "$ROUTING_JSON" ]; then
  echo "ERROR: routing.json not found at $ROUTING_JSON"
  exit 1
fi

if ! command -v jq &>/dev/null; then
  echo "ERROR: jq is required but not installed"
  exit 1
fi

# ─── Helpers ─────────────────────────────────────────────────────────────────

get_agents() {
  jq -r '.agents | keys[]' "$ROUTING_JSON"
}

agent_matches() {
  local agent="$1"
  local status="$2"
  local labels="$3"
  local desc_state="$4"

  local rules
  rules=$(jq -c ".agents.${agent}.rules" "$ROUTING_JSON")

  local status_match
  status_match=$(echo "$rules" | jq -r --arg s "$status" '.status_in | map(select(. == $s)) | length')
  if [ "$status_match" -eq 0 ]; then
    return 1
  fi

  local labels_include
  labels_include=$(echo "$rules" | jq -r '.labels_include // empty')
  if [ -n "$labels_include" ]; then
    local found=0
    local req_label
    while IFS= read -r req_label; do
      if echo ",$labels," | grep -q ",$req_label,"; then
        found=1
        break
      fi
    done < <(echo "$rules" | jq -r '.labels_include[]')
    if [ "$found" -eq 0 ]; then
      return 1
    fi
  fi

  local labels_exclude
  labels_exclude=$(echo "$rules" | jq -r '.labels_exclude // empty')
  if [ -n "$labels_exclude" ]; then
    local excl_label
    while IFS= read -r excl_label; do
      if echo ",$labels," | grep -q ",$excl_label,"; then
        return 1
      fi
    done < <(echo "$rules" | jq -r '.labels_exclude[]')
  fi

  local desc_cond
  desc_cond=$(echo "$rules" | jq -r '.description_condition // "null"')

  case "$desc_cond" in
    "null"|"")
      ;;
    "empty_or_todo_or_label_needs_planning")
      local has_needs_planning=0
      if echo ",$labels," | grep -q ",needs-planning,"; then
        has_needs_planning=1
      fi
      if [ "$desc_state" != "empty" ] && [ "$desc_state" != "todo" ] && [ "$has_needs_planning" -eq 0 ]; then
        return 1
      fi
      ;;
    "not_empty_and_not_todo")
      if [ "$desc_state" = "empty" ] || [ "$desc_state" = "todo" ]; then
        return 1
      fi
      ;;
    *)
      echo "WARNING: Unknown description_condition: $desc_cond" >&2
      ;;
  esac

  return 0
}

# ─── Modes ───────────────────────────────────────────────────────────────────

run_simulation() {
  local show_matrix="${1:-false}"
  local desc_states=("empty" "todo" "filled")

  local statuses=()
  while IFS= read -r line; do statuses+=("$line"); done < <(jq -r '.statuses[]' "$ROUTING_JSON")

  local all_labels=()
  while IFS= read -r line; do all_labels+=("$line"); done < <(jq -r '.labels[]' "$ROUTING_JSON")

  # Build label combos: singles + realistic multi-label pairs
  local label_combos=("none")
  for l in "${all_labels[@]}"; do
    label_combos+=("$l")
  done
  label_combos+=("needs-tests,needs-planning")
  label_combos+=("tech-debt,needs-planning")
  label_combos+=("needs-tests,tech-debt")
  label_combos+=("ralph-blocked,needs-planning")
  label_combos+=("needs-tests,ralph-blocked")
  label_combos+=("documented,tech-debt")
  label_combos+=("needs-input,needs-planning")
  label_combos+=("needs-input,needs-tests")
  label_combos+=("needs-input,ralph-blocked")

  local agents=()
  while IFS= read -r line; do agents+=("$line"); done < <(get_agents)

  local overlap_count=0
  local gap_count=0
  local total=0

  if [ "$show_matrix" = "true" ]; then
    printf "%-14s %-30s %-8s |" "STATUS" "LABELS" "DESC"
    for agent in "${agents[@]}"; do
      printf " %-4s" "${agent:0:4}"
    done
    printf " | RESULT\n"
    printf '%120s\n' '' | tr ' ' '-'
  fi

  for status in "${statuses[@]}"; do
    for labels in "${label_combos[@]}"; do
      for desc in "${desc_states[@]}"; do
        total=$((total + 1))
        local matches=()

        for agent in "${agents[@]}"; do
          if agent_matches "$agent" "$status" "$labels" "$desc"; then
            matches+=("$agent")
          fi
        done

        local match_count=${#matches[@]}
        local result=""

        if [ "$match_count" -eq 0 ]; then
          result="GAP"
          gap_count=$((gap_count + 1))
        elif [ "$match_count" -eq 1 ]; then
          result="ok (${matches[0]})"
        else
          result="OVERLAP: ${matches[*]}"
          overlap_count=$((overlap_count + 1))
        fi

        if [ "$show_matrix" = "true" ]; then
          printf "%-14s %-30s %-8s |" "$status" "$labels" "$desc"
          for agent in "${agents[@]}"; do
            local mark=" . "
            for m in "${matches[@]}"; do
              if [ "$m" = "$agent" ]; then
                mark=" X "
                break
              fi
            done
            printf " %-4s" "$mark"
          done
          printf " | %s\n" "$result"
        elif [ "$match_count" -ne 1 ]; then
          printf "%-14s %-30s %-8s -> %s\n" "$status" "$labels" "$desc" "$result"
        fi
      done
    done
  done

  echo ""
  echo "=== Summary ==="
  echo "Total states simulated: $total"
  echo "Overlaps: $overlap_count"
  echo "Gaps: $gap_count"

  if [ "$overlap_count" -gt 0 ]; then
    echo ""
    echo "FAIL: $overlap_count overlap(s) found. Multiple agents would claim the same ticket."
    return 1
  fi

  if [ "$gap_count" -gt 0 ]; then
    echo ""
    echo "INFO: $gap_count gap(s) found. Some ticket states have no agent assigned."
    echo "(Gaps may be intentional — e.g., tickets in 'In Review' with 'needs-planning' label.)"
  fi

  echo ""
  echo "PASS: No overlaps detected."
  return 0
}

check_prompts() {
  local exit_code=0

  echo "Checking JQL drift between routing.json and prompt files..."
  echo ""

  local agent
  for agent in $(get_agents); do
    local json_jql
    local prompt_file
    json_jql=$(jq -r ".agents.${agent}.jql" "$ROUTING_JSON")
    prompt_file=$(jq -r ".agents.${agent}.prompt" "$ROUTING_JSON")

    local full_prompt_path="$RALPH_HOME/$prompt_file"
    if [ ! -f "$full_prompt_path" ]; then
      echo "WARNING: Prompt file not found: $prompt_file"
      exit_code=1
      continue
    fi

    local prompt_jql=""
    prompt_jql=$(sed -n 's/.*\*\*JQL\*\*: `\(.*\)`$/\1/p' "$full_prompt_path" 2>/dev/null | head -1 || true)

    if [ -z "$prompt_jql" ]; then
      prompt_jql=$(sed -n '/\*\*JQL\*\*/{n;p;}' "$full_prompt_path" 2>/dev/null | head -1 | sed 's/^[[:space:]]*//' | sed 's/`//g' || true)
    fi

    if [ -z "$prompt_jql" ]; then
      prompt_jql=$(sed -n '/with JQL:/{n;p;}' "$full_prompt_path" 2>/dev/null | head -1 | sed 's/^[[:space:]]*//' | sed 's/`//g' || true)
    fi

    if [ -z "$prompt_jql" ]; then
      prompt_jql=$(grep 'assignee = currentUser()' "$full_prompt_path" 2>/dev/null | grep '`' | head -1 | sed 's/^[[:space:]]*//' | sed 's/`//g' || true)
    fi

    if [ -z "$prompt_jql" ]; then
      echo "WARNING: Could not extract JQL from $prompt_file for agent '$agent'"
      exit_code=1
      continue
    fi

    local norm_json
    local norm_prompt
    norm_json=$(echo "$json_jql" | sed "s/'/\"/g")
    norm_prompt=$(echo "$prompt_jql" | sed "s/'/\"/g")

    if [ "$norm_json" = "$norm_prompt" ]; then
      echo "  $agent: OK"
    else
      echo "  $agent: DRIFT DETECTED"
      echo "    routing.json: $json_jql"
      echo "    $prompt_file: $prompt_jql"
      echo ""
      exit_code=1
    fi
  done

  echo ""
  if [ "$exit_code" -eq 0 ]; then
    echo "PASS: No JQL drift detected."
  else
    echo "FAIL: JQL drift detected. Update routing.json or prompt files to match."
  fi

  return $exit_code
}

check_loops() {
  local exit_code=0

  echo "Checking for self-loop risks and global-exclude violations..."
  echo ""

  # ─── 1. Global label excludes ─────────────────────────────────────────────
  local global_excludes=()
  while IFS= read -r line; do
    [ -n "$line" ] && global_excludes+=("$line")
  done < <(jq -r '.global_label_excludes[]? // empty' "$ROUTING_JSON")

  if [ ${#global_excludes[@]} -eq 0 ]; then
    echo "  WARNING: No global_label_excludes defined in routing.json"
    echo "  (Consider adding labels like 'needs-input' that no agent should process.)"
    echo ""
  else
    echo "  Global label excludes: ${global_excludes[*]}"
    echo ""

    for agent in $(get_agents); do
      local agent_excludes
      agent_excludes=$(jq -r ".agents.${agent}.rules.labels_exclude // [] | .[]" "$ROUTING_JSON")

      for gl in "${global_excludes[@]}"; do
        if echo "$agent_excludes" | grep -qx "$gl"; then
          echo "  $agent excludes '$gl': OK"
        else
          echo "  $agent excludes '$gl': FAIL — agent can pick up tickets with '$gl'"
          exit_code=1
        fi
      done
    done
  fi

  echo ""

  # ─── 2. Self-loop detection ───────────────────────────────────────────────
  echo "  Checking adds_labels vs labels_exclude..."
  echo ""

  local has_adds_labels=0

  for agent in $(get_agents); do
    local adds_labels_json
    adds_labels_json=$(jq -r ".agents.${agent}.adds_labels // empty" "$ROUTING_JSON")

    if [ -z "$adds_labels_json" ]; then
      echo "  $agent: WARNING — no adds_labels defined (cannot verify self-loop safety)"
      continue
    fi

    has_adds_labels=1
    local adds_labels=()
    while IFS= read -r line; do
      [ -n "$line" ] && adds_labels+=("$line")
    done < <(jq -r ".agents.${agent}.adds_labels[]" "$ROUTING_JSON")

    if [ ${#adds_labels[@]} -eq 0 ]; then
      echo "  $agent: OK (adds no labels)"
      continue
    fi

    local agent_excludes
    agent_excludes=$(jq -r ".agents.${agent}.rules.labels_exclude // [] | .[]" "$ROUTING_JSON")

    local agent_ok=1
    for label in "${adds_labels[@]}"; do
      if echo "$agent_excludes" | grep -qx "$label"; then
        echo "  $agent adds '$label' and excludes it: OK"
      else
        echo "  $agent adds '$label' but does NOT exclude it: WARN — potential self-loop"
        echo "    (If the agent also transitions status, this may be safe. Verify the workflow.)"
        # Treat as warning, not hard fail — some agents intentionally reprocess
      fi
    done
  done

  if [ "$has_adds_labels" -eq 0 ]; then
    echo ""
    echo "  WARNING: No agents define adds_labels. Add this field to enable self-loop detection."
  fi

  echo ""
  if [ "$exit_code" -eq 0 ]; then
    echo "PASS: No global-exclude violations detected."
  else
    echo "FAIL: Global-exclude violations found. Every agent must exclude all global_label_excludes labels."
  fi

  return $exit_code
}

check_core() {
  local exit_code=0 pass=0 fail=0
  local test_tmpdir
  test_tmpdir=$(mktemp -d)

  echo "Checking core behaviors..."
  echo ""

  # Verify zsh is available (Ralph agents require it)
  if ! command -v zsh &>/dev/null; then
    echo "  SKIP: zsh not available (required for core behavior tests)"
    return 0
  fi

  # Helper: run a zsh snippet with ralph-core.sh sourced (in clean dir to avoid .ralphrc)
  run_zsh() {
    (cd "$test_tmpdir" && zsh -c "RALPH_HOME='$RALPH_HOME'; source '$RALPH_HOME/lib/ralph-core.sh'; $1") 2>/dev/null
  }

  assert_ok() {
    echo "  $1: OK"
    pass=$((pass + 1))
  }

  assert_fail() {
    echo "  $1: FAIL"
    [ -n "${2:-}" ] && echo "    $2"
    fail=$((fail + 1))
    exit_code=1
  }

  # ─── Story 1: Correct CLI for each model provider ─────────────────────

  local result
  for provider in claude gemini codex; do
    result=$(run_zsh "RALPH_MODEL_PROVIDER=$provider; ralph_get_agent_cli")
    if [ "$result" = "$provider" ]; then
      assert_ok "Ralph invokes correct CLI for $provider"
    else
      assert_fail "Ralph invokes correct CLI for $provider" "expected '$provider', got '$result'"
    fi
  done

  # ─── Story 2: Reject unknown model provider ───────────────────────────

  local bogus_exit=0
  run_zsh "RALPH_MODEL_PROVIDER=bogus; ralph_init" || bogus_exit=$?
  if [ "$bogus_exit" -ne 0 ]; then
    assert_ok "Ralph rejects unknown model provider"
  else
    assert_fail "Ralph rejects unknown model provider" "expected non-zero exit, got 0"
  fi

  # ─── Fixtures ─────────────────────────────────────────────────────────

  local claude_fixture gemini_fixture codex_fixture
  claude_fixture='{"type":"assistant","message":{"content":[{"type":"text","text":"Working on PROD-42..."}]}}
{"type":"result","result":"Done. <promise>COMPLETE</promise>"}'

  gemini_fixture='{"type":"message","role":"assistant","content":"Working on PROD-42..."}
{"type":"message","role":"assistant","content":"Done. <promise>COMPLETE</promise>"}'

  codex_fixture='{"type":"item.completed","item":{"type":"agent_message","text":"Working on PROD-42..."}}
{"type":"item.completed","item":{"type":"agent_message","text":"Done. <promise>COMPLETE</promise>"}}'

  local claude_abort='{"type":"result","result":"Failed. <promise>ABORT</promise>"}'
  local gemini_abort='{"type":"message","role":"assistant","content":"Failed. <promise>ABORT</promise>"}'
  local codex_abort='{"type":"item.completed","item":{"type":"agent_message","text":"Failed. <promise>ABORT</promise>"}}'

  # Extract jq filters from ralph-core.sh via zsh
  local claude_stream claude_result_f gemini_stream gemini_result_f codex_stream codex_result_f
  claude_stream=$(run_zsh 'RALPH_MODEL_PROVIDER=claude; ralph_get_jq_filters; printf "%s" "$RALPH_STREAM_FILTER"')
  claude_result_f=$(run_zsh 'RALPH_MODEL_PROVIDER=claude; ralph_get_jq_filters; printf "%s" "$RALPH_RESULT_FILTER"')
  gemini_stream=$(run_zsh 'RALPH_MODEL_PROVIDER=gemini; ralph_get_jq_filters; printf "%s" "$RALPH_STREAM_FILTER"')
  gemini_result_f=$(run_zsh 'RALPH_MODEL_PROVIDER=gemini; ralph_get_jq_filters; printf "%s" "$RALPH_RESULT_FILTER"')
  codex_stream=$(run_zsh 'RALPH_MODEL_PROVIDER=codex; ralph_get_jq_filters; printf "%s" "$RALPH_STREAM_FILTER"')
  codex_result_f=$(run_zsh 'RALPH_MODEL_PROVIDER=codex; ralph_get_jq_filters; printf "%s" "$RALPH_RESULT_FILTER"')

  # ─── Story 3: Stream output through jq filters ────────────────────────

  local fixture_var filter_var output
  for provider in claude gemini codex; do
    fixture_var="${provider}_fixture"
    filter_var="${provider}_stream"
    output=$(printf '%s\n' "${!fixture_var}" | jq -rj "${!filter_var}" 2>/dev/null || true)
    if [ -n "$output" ] && echo "$output" | grep -q "PROD-42"; then
      assert_ok "Ralph streams $provider output through jq"
    else
      assert_fail "Ralph streams $provider output through jq" "output was empty or missing PROD-42"
    fi
  done

  # ─── Story 4: Detect <promise>COMPLETE</promise> ──────────────────────

  for provider in claude gemini codex; do
    fixture_var="${provider}_fixture"
    filter_var="${provider}_result_f"
    output=$(printf '%s\n' "${!fixture_var}" | jq -r "${!filter_var}" 2>/dev/null || true)
    if echo "$output" | grep -q '<promise>COMPLETE</promise>'; then
      assert_ok "Ralph detects COMPLETE promise for $provider"
    else
      assert_fail "Ralph detects COMPLETE promise for $provider" "promise not found in result"
    fi
  done

  # ─── Story 5: Detect <promise>ABORT</promise> ─────────────────────────

  for provider in claude gemini codex; do
    fixture_var="${provider}_abort"
    filter_var="${provider}_result_f"
    output=$(printf '%s\n' "${!fixture_var}" | jq -r "${!filter_var}" 2>/dev/null || true)
    if echo "$output" | grep -q '<promise>ABORT</promise>'; then
      assert_ok "Ralph detects ABORT promise for $provider"
    else
      assert_fail "Ralph detects ABORT promise for $provider" "promise not found in result"
    fi
  done

  # ─── Story 6: No cross-match between providers ────────────────────────

  local src tgt
  for src in claude gemini codex; do
    for tgt in claude gemini codex; do
      [ "$src" = "$tgt" ] && continue
      fixture_var="${src}_fixture"
      filter_var="${tgt}_stream"
      output=$(printf '%s\n' "${!fixture_var}" | jq -rj "${!filter_var}" 2>/dev/null || true)
      output=$(echo "$output" | tr -d '[:space:]')
      if [ -z "$output" ]; then
        assert_ok "No cross-match: $src fixture through $tgt filter"
      else
        assert_fail "No cross-match: $src fixture through $tgt filter" "unexpected output: $output"
      fi
    done
  done

  # ─── Story 7: Titlebar contains iteration number ──────────────────────

  if grep -q 'Iteration $iteration' "$RALPH_HOME/lib/ralph-gated-loop.sh"; then
    assert_ok "Gated loop titlebar shows iteration number"
  else
    assert_fail "Gated loop titlebar shows iteration number"
  fi
  if grep -q 'Iteration $iteration' "$RALPH_HOME/lib/ralph-github-loop.sh"; then
    assert_ok "GitHub loop titlebar shows iteration number"
  else
    assert_fail "GitHub loop titlebar shows iteration number"
  fi

  # ─── Story 8: Poll interval configuration ─────────────────────────────

  local interval
  interval=$(run_zsh 'unset RALPH_POLL_INTERVAL; ralph_get_poll_interval')
  if [ "$interval" = "15" ]; then
    assert_ok "Ralph defaults poll interval to 15"
  else
    assert_fail "Ralph defaults poll interval to 15" "got '$interval'"
  fi
  interval=$(run_zsh 'RALPH_POLL_INTERVAL=30; ralph_get_poll_interval')
  if [ "$interval" = "30" ]; then
    assert_ok "Ralph respects custom poll interval"
  else
    assert_fail "Ralph respects custom poll interval" "expected 30, got '$interval'"
  fi

  # ─── Story 9: Session log saved when RALPH_LOG_DIR is set ─────────────

  local log_dir="$test_tmpdir/logs"
  echo '{"type":"test"}' > "$test_tmpdir/session.json"
  run_zsh "RALPH_LOG_DIR='$log_dir'; ralph_save_session_log '$test_tmpdir/session.json' 'test-agent' '1' 'TASK-1'"
  if ls "$log_dir"/test-agent-1/*.log &>/dev/null; then
    assert_ok "Ralph saves session log when RALPH_LOG_DIR is set"
  else
    assert_fail "Ralph saves session log when RALPH_LOG_DIR is set" "no .log files found"
  fi

  # ─── Story 10: Session log path printed to stdout ────────────────────

  local log_output
  log_output=$(run_zsh "RALPH_LOG_DIR='$log_dir'; ralph_save_session_log '$test_tmpdir/session.json' 'test-agent' '1' 'TASK-2'")
  if echo "$log_output" | grep -q "Session log:.*test-agent-1/.*TASK-2.log"; then
    assert_ok "Ralph prints session log path before exiting"
  else
    assert_fail "Ralph prints session log path before exiting" "output: $log_output"
  fi

  # ─── Story 11: Extract task key from stream output ────────────────────

  echo '{"text":"Working on PROD-42 now"}' > "$test_tmpdir/taskkey.txt"
  result=$(run_zsh "ralph_extract_task_key '$test_tmpdir/taskkey.txt'")
  if [ "$result" = "PROD-42" ]; then
    assert_ok "Ralph extracts task key PROD-42"
  else
    assert_fail "Ralph extracts task key PROD-42" "got '$result'"
  fi

  echo '{"text":"no key here"}' > "$test_tmpdir/nokey.txt"
  result=$(run_zsh "ralph_extract_task_key '$test_tmpdir/nokey.txt'")
  if [ -z "$result" ]; then
    assert_ok "Ralph returns empty for missing task key"
  else
    assert_fail "Ralph returns empty for missing task key" "got '$result'"
  fi

  # ─── Story 11: All prompt and provider files exist ─────────────────────

  local agent prompt_path
  for agent in $(get_agents); do
    prompt_path=$(jq -r ".agents.${agent}.prompt" "$ROUTING_JSON")
    if [ -f "$RALPH_HOME/$prompt_path" ]; then
      assert_ok "Prompt file exists: $agent"
    else
      assert_fail "Prompt file exists: $agent" "missing: $prompt_path"
    fi
  done

  if [ -f "$RALPH_HOME/providers/$RALPH_PROVIDER/instructions.md" ]; then
    assert_ok "Provider instructions file exists"
  else
    assert_fail "Provider instructions file exists" "missing: providers/$RALPH_PROVIDER/instructions.md"
  fi

  # ─── Cleanup & Summary ────────────────────────────────────────────────

  rm -rf "$test_tmpdir"

  echo ""
  if [ "$exit_code" -eq 0 ]; then
    echo "PASS: All $pass core behavior checks passed."
  else
    echo "FAIL: $fail of $((pass + fail)) core behavior checks failed."
  fi

  return $exit_code
}

# ─── Main ────────────────────────────────────────────────────────────────────

case "${1:-}" in
  --matrix)
    run_simulation true
    ;;
  --check-prompts)
    check_prompts
    ;;
  --check-loops)
    check_loops
    ;;
  --check-core)
    check_core
    ;;
  --check-all)
    all_exit=0
    echo "=========================================="
    echo "  Ralph Routing Validator — Full Check"
    echo "=========================================="
    echo ""
    echo "--- Simulation (overlaps/gaps) ---"
    echo ""
    run_simulation false || all_exit=1
    echo ""
    echo "--- JQL Drift ---"
    echo ""
    check_prompts || all_exit=1
    echo ""
    echo "--- Self-Loop & Global Excludes ---"
    echo ""
    check_loops || all_exit=1
    echo ""
    echo "--- Core Behaviors ---"
    echo ""
    check_core || all_exit=1
    echo ""
    echo "=========================================="
    if [ "$all_exit" -eq 0 ]; then
      echo "  ALL CHECKS PASSED"
    else
      echo "  SOME CHECKS FAILED"
    fi
    echo "=========================================="
    exit $all_exit
    ;;
  --help|-h)
    echo "Usage: validate-routing [--matrix | --check-prompts | --check-loops | --check-core | --check-all]"
    echo ""
    echo "  (default)        Simulate ticket states, report overlaps and gaps"
    echo "  --matrix         Full matrix output showing all agents vs all states"
    echo "  --check-prompts  Check JQL drift between routing.json and prompt files"
    echo "  --check-loops    Check for self-loop risks and global-exclude violations"
    echo "  --check-core     Check core behaviors (CLI routing, jq filters, promises, etc.)"
    echo "  --check-all      Run all checks (simulation + prompts + loops + core)"
    exit 0
    ;;
  "")
    run_simulation false
    ;;
  *)
    echo "Unknown option: $1"
    echo "Usage: validate-routing [--matrix | --check-prompts | --check-loops | --check-core | --check-all]"
    exit 1
    ;;
esac
