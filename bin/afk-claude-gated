#!/bin/zsh
set -e
RALPH_HOME="$(cd "$(dirname "$(realpath "$0")")/.." && pwd)"
source "$RALPH_HOME/lib/ralph-core.sh"
ralph_init
ralph_load_provider

# Validate provider-specific env vars
ralph_validate_env $PROVIDER_ENV_VARS

# Use custom query or default "all non-done tasks"
RALPH_CUSTOM_QUERY="${RALPH_CUSTOM_QUERY:-assignee = currentUser() AND status != Done ORDER BY priority DESC, rank ASC}"

provider_instructions="$(ralph_get_provider_instructions)"
prompt_file="$RALPH_HOME/prompts/generic.md"
poll_interval="$(ralph_get_poll_interval)"

if [[ ! -f "$prompt_file" ]]; then
  ralph_error "Prompt not found: $prompt_file"
  exit 1
fi

if [[ ! -f "$provider_instructions" ]]; then
  ralph_error "Provider instructions not found: $provider_instructions"
  exit 1
fi

# jq filters
stream_text='select(.type == "assistant").message.content[]? | select(.type == "text").text // empty | gsub("\n"; "\r\n") | . + "\r\n\n"'
final_result='select(.type == "result").result // empty'

iteration=0
tmpfile=""
child_pid=""
shutdown=0

trap 'shutdown=1' INT TERM
trap 'ralph_titlebar_cleanup; rm -f "$tmpfile" 2>/dev/null' EXIT

die() {
  ralph_titlebar_cleanup
  printf "\nShutting down.\n"
  rm -f "$tmpfile" 2>/dev/null
  tmpfile=""
  [[ -n "$child_pid" ]] && kill -9 "$child_pid" 2>/dev/null
  kill -9 0 2>/dev/null
  exit 1
}

ralph_titlebar_init

while true; do
  task_count=$(provider_check_tasks "$RALPH_CUSTOM_QUERY")

  if [[ "$task_count" -eq 0 ]]; then
    ralph_titlebar_update "AFK | Waiting | No tasks | $(date '+%H:%M:%S')"
    ralph_log "No tasks assigned. Sleeping ${poll_interval}s..."
    sleep "$poll_interval" &
    child_pid=$!
    wait $child_pid 2>/dev/null || true
    child_pid=""
    [[ $shutdown -eq 1 ]] && die
    continue
  fi

  iteration=$((iteration + 1))
  tmpfile=$(mktemp)

  ralph_titlebar_update "Iteration $iteration | Tasks: $task_count | $(date '+%H:%M:%S')"
  echo "------- ITERATION $iteration ($task_count tasks) --------"

  claude \
    --verbose \
    --print \
    --output-format stream-json \
    --dangerously-skip-permissions \
    --append-system-prompt "$(cat "$provider_instructions")" \
    "@$prompt_file" \
  | grep --line-buffered '^{' \
  | tee "$tmpfile" \
  | jq --unbuffered -rj "$stream_text" &
  child_pid=$!
  wait $child_pid 2>/dev/null || true
  child_pid=""
  [[ $shutdown -eq 1 ]] && die

  result=$(jq -r "$final_result" "$tmpfile")
  rm -f "$tmpfile"
  tmpfile=""

  if [[ "$result" == *"<promise>ABORT</promise>"* ]]; then
    echo "Ralph aborted at iteration $iteration."
    exit 1
  fi

  # COMPLETE or normal finish → loop back and re-check
done
